# Copy this file to .env and add your PageSpeed Insights API key.
# Either name is supported; PAGESPEED_API_KEY is preferred.
PAGESPEED_API_KEY=your_pagespeed_api_key_here
# PSI_API_KEY=your_pagespeed_api_key_here

# Optional: set false to skip docx2pdf/Microsoft Word PDF export.
# GAPFINDER_EXPORT_PDF=false

# Optional HAR capture tuning for slow or script-heavy sites.
# GAPFINDER_PAGE_TIMEOUT_MS=45000
# GAPFINDER_NETWORK_IDLE_MS=2000
# GAPFINDER_CONTEXT_CLOSE_TIMEOUT_MS=8000
